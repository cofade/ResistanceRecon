# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ML / experiment tracking
mlruns/
*.joblib
*.pkl

# Data & model artifacts (large; published as release assets / reproducible via scripts)
data/raw/
data/interim/
data/processed/
# models/: commit the small TEXT artifacts (feature_schema/metrics/conformal/coefficients JSON,
# model_card.md, registry.json, results_summary.json) as reproducible ground-truth; the binary
# models (*.joblib, caught globally above) and MLflow runs (mlruns/) stay out.
models/*
!models/.gitkeep
!models/*/
!models/**/*.json
!models/**/*.md

# Secrets
.env
.env.*
!.env.example
*.key

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Keep small test fixtures tracked
!tests/fixtures/**

# MCP config can contain API keys — never commit
.claude/.mcp.json
.mcp.json

# Internal reuse map references private projects — keep local, do not publish
Documentation/reuse-inventory.md
