# Copy to .env (gitignored) and fill in. Read by genome_firewall.llm.settings.LLMSettings.
#
# Used ONLY for the real OpenAI grounded-narrative path (EPIC 5). When OPENAI_API_KEY is
# absent -- as in CI and every automated test -- the narrative pipeline serves the
# deterministic template (review_status=llm_disabled). No prediction ever depends on it.
OPENAI_API_KEY=

# Model + reasoning defaults (also the code defaults in genome_firewall.llm.settings).
# Default model is GPT-5.6 Luna, a reasoning model. Override via OPENAI_MODEL.
OPENAI_MODEL=gpt-5.6-luna
#
# Reasoning effort ("Extra High" = xhigh). Accepted values: none | low | medium | high | xhigh.
# Must be compatible with OPENAI_MODEL (gpt-5.x reasoning models accept all five; classic chat
# models like gpt-4o accept none/omitted only). Reasoning models reject an explicit temperature.
OPENAI_REASONING_EFFORT=xhigh
